# Measure tools/list payload size; useful for regression-watching
# tool description bloat (issue: #11364). Set FAIL_OVER_CHARS=N to fail
# the recipe when the total exceeds N (CI guard); leave unset to just print.
measure-tools:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -x "{{ server_bin }}" ]; then
        echo "Server binary not found: {{ server_bin }}"
        echo "Run 'just build' first"
        exit 1
    fi
    if ! command -v jq >/dev/null 2>&1; then
        echo "jq is required (brew install jq)"
        exit 1
    fi
    BIN="{{ server_bin }}" TOP="${TOP:-10}" \
        FAIL_OVER_CHARS="${FAIL_OVER_CHARS:-0}" \
        bash ./measure_tools.sh

# Run crash-guard integration test
# Verifies that SIGSEGV during a handler call is caught and converted to a
# ToolError instead of killing the server. Triggers a real segfault via
# IDAPython ctypes.string_at(0) and checks the session_id stays stable

# across the crash (proof the server process didn't restart).
test-crash-guard: test-bootstrap
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -x "{{ server_bin }}" ]; then
        echo "Server binary not found: {{ server_bin }}"
        exit 1
    fi
    if ! command -v jq &>/dev/null; then
        echo "jq is required for crash-guard test (brew install jq)"
        exit 1
    fi
    LOCK="{{ test_lock }}"
    if [ -f "$LOCK" ]; then
        pid=$(awk -F= '$1=="pid"{print $2}' "$LOCK" | tr -d '\r')
        if [ -n "$pid" ] && kill -0 "$pid" 2>/dev/null; then
            echo "Lock file $LOCK is held by pid $pid; close that server first." >&2
            exit 1
        else
            rm -f "$LOCK"
        fi
    fi
    echo "🧪 Running crash-guard integration test..."

    fifo_in="$(mktemp -u).fifo"
    mkfifo "$fifo_in"
    log="$(mktemp)"

    RUST_LOG="{{ rust_log }}" "{{ server_bin }}" < "$fifo_in" > "$log" 2>&1 &
    server_pid=$!
    exec 3>"$fifo_in"

    cleanup() {
        exec 3>&- || true
        rm -f "$fifo_in"
        kill "$server_pid" 2>/dev/null || true
        wait "$server_pid" 2>/dev/null || true
    }
    trap cleanup EXIT

    send() { echo "$1" >&3; }

    wait_response() {
        local target_id="$1"
        local timeout="${2:-30}"
        local elapsed=0
        while [ "$elapsed" -lt "$timeout" ]; do
            local line
            line=$(grep -m1 "\"id\":${target_id}[,}]" "$log" 2>/dev/null | grep '"jsonrpc"' || true)
            if [ -n "$line" ]; then
                echo "$line"
                return 0
            fi
            if ! kill -0 "$server_pid" 2>/dev/null; then
                echo "   ❌ server process died waiting for id=$target_id" >&2
                cat "$log" >&2
                return 1
            fi
            sleep 1
            elapsed=$((elapsed + 1))
        done
        echo "Timeout waiting for response id=$target_id" >&2
        return 1
    }

    # Init
    send '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05","clientInfo":{"name":"cg","version":"0.1"},"capabilities":{}}}'
    send '{"jsonrpc":"2.0","method":"notifications/initialized","params":{}}'
    wait_response 1 10 >/dev/null
    echo "   initialized"

    # Open the pre-built .i64 fixture
    send '{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"open_idb","arguments":{"path":"fixtures/mini.i64"}}}'
    open_resp=$(wait_response 2 30)
    session_before=$(echo "$open_resp" | jq -r '.result.content[0].text' | jq -r '.session_id // empty')
    if [ -z "$session_before" ]; then
        echo "❌ open_idb did not return a session_id"
        echo "$open_resp" | jq .
        exit 1
    fi
    echo "   opened session=${session_before:0:8}"

    # Test 1: decompile at invalid address — clean error path through the guard
    send '{"jsonrpc":"2.0","id":3,"method":"tools/call","params":{"name":"decompile","arguments":{"address":"0xDEADBEEF"}}}'
    resp=$(wait_response 3 10)
    text=$(echo "$resp" | jq -r '.result.content[0].text // empty')
    echo "   decompile 0xDEADBEEF → ${text:0:60}"

    # Test 2: deliberate SIGSEGV via IDAPython — Linux-only.
    # macOS delivers EXC_BAD_ACCESS as a Mach exception which bypasses Unix
    # signal handlers when IDA registers its own Mach handler. The crash guard
    # works for IDA-internal crashes on both platforms (verified against
    # kernelcache decompile) but this synthetic ctypes.string_at(0) path
    # exercises signal-delivered SIGSEGV which only works on Linux.
    if [ "$(uname -s)" = "Linux" ]; then
        # Raise SIGSEGV synchronously on the IDA worker thread. Expected
        # outcome: the signal is caught, an ERROR is logged, but the
        # run_script response itself may be dropped (tokio foreground
        # operation machinery is in a weird state after siglongjmp skipped
        # its destructors). The real verification is that the SERVER is
        # still alive and processing subsequent requests.
        send '{"jsonrpc":"2.0","id":4,"method":"tools/call","params":{"name":"run_script","arguments":{"code":"import signal\nsignal.raise_signal(signal.SIGSEGV)"}}}'
        sleep 3   # let the crash path complete and log the ERROR line
        if ! grep -q 'crashed in IDA SDK (signal 11)\|signal 11 caught' "$log"; then
            echo "❌ expected crash-guard catch message not in log" >&2
            tail -20 "$log" >&2
            exit 1
        fi
        echo "   SIGSEGV caught by guard (ERROR logged)"
    else
        echo "   (skipping forced SIGSEGV on macOS — Mach exceptions bypass signal handlers)"
    fi

    # Test 3: server is still alive and session_id is unchanged
    # (this is the real proof the crash guard did its job — server survived
    # the signal and can still process new requests on the same session)
    send '{"jsonrpc":"2.0","id":5,"method":"tools/call","params":{"name":"analysis_status","arguments":{}}}'
    resp=$(wait_response 5 15) || { echo "❌ server died or hung after Test 2"; exit 1; }
    session_after=$(echo "$resp" | jq -r '.result.content[0].text' | jq -r '.session_id // empty')
    if [ "$session_before" != "$session_after" ]; then
        echo "❌ session_id changed: ${session_before:0:8} → ${session_after:0:8} (server restarted)"
        exit 1
    fi
    echo "   server alive after crash, session_id stable: ${session_after:0:8}"

    # Close
    send '{"jsonrpc":"2.0","id":99,"method":"tools/call","params":{"name":"close_idb","arguments":{}}}'
    wait_response 99 10 >/dev/null
    echo "✅ Crash-guard test passed"

dsc_test_path := env_var_or_default("DSC_TEST_PATH", "/tmp/ios_sys_mount/System/Library/Caches/com.apple.dyld/dyld_shared_cache_arm64e")

# Run dyld_shared_cache (DSC) integration test

# Handles both sync (pre-existing .i64) and async (background task) paths.
test-dsc dsc_path=dsc_test_path:
    #!/usr/bin/env bash
    set -euo pipefail
    if [ ! -x "{{ server_bin }}" ]; then
        echo "Server binary not found: {{ server_bin }}"
        echo "Run 'cargo build --release' first"
        exit 1
    fi
    if ! command -v jq &>/dev/null; then
        echo "jq is required for DSC test (brew install jq)"
        exit 1
    fi
    echo "🧪 Running DSC integration test..."
    echo "   DSC: {{ dsc_path }}"

    fifo_in="$(mktemp -u).fifo"
    mkfifo "$fifo_in"
    log="$(mktemp)"

    # Start server with fifo as stdin
    RUST_LOG="{{ rust_log }}" "{{ server_bin }}" < "$fifo_in" > "$log" 2>&1 &
    server_pid=$!
    # Open the write end of fifo (keeps it open so server doesn't see EOF)
    exec 3>"$fifo_in"

    cleanup() {
        exec 3>&- || true
        rm -f "$fifo_in"
        kill "$server_pid" 2>/dev/null || true
        wait "$server_pid" 2>/dev/null || true
    }
    trap cleanup EXIT

    send() { echo "$1" >&3; }

    # Wait for a JSON-RPC response with the given id.
    # Reads from the log file, skipping log lines (which start with a timestamp).
    wait_response() {
        local target_id="$1"
        local timeout="${2:-300}"
        local elapsed=0
        while [ "$elapsed" -lt "$timeout" ]; do
            # Look for a JSON line with matching id
            local line
            line=$(grep -m1 "\"id\":${target_id}[,}]" "$log" 2>/dev/null | grep '"jsonrpc"' || true)
            if [ -n "$line" ]; then
                echo "$line"
                return 0
            fi
            sleep 1
            elapsed=$((elapsed + 1))
        done
        echo "Timeout waiting for response id=$target_id" >&2
        return 1
    }

    # Phase 1: Initialize
    send '{"jsonrpc":"2.0","id":1,"method":"initialize","params":{"protocolVersion":"2024-11-05","clientInfo":{"name":"dsc-test","version":"0.1"},"capabilities":{}}}'
    send '{"jsonrpc":"2.0","method":"notifications/initialized","params":{}}'
    wait_response 1 10 >/dev/null
    echo "   Initialized"

    # Phase 2: open_dsc
    payload=$(sed "s|DSC_PATH|{{ dsc_path }}|g" <<< '{"jsonrpc":"2.0","id":2,"method":"tools/call","params":{"name":"open_dsc","arguments":{"path":"DSC_PATH","arch":"arm64e","module":"/System/Library/PrivateFrameworks/LockdownMode.framework/LockdownMode"}}}')
    send "$payload"
    resp=$(wait_response 2 30)
    echo "   open_dsc responded"

    # Check if we got a task_id (async) or direct db_info (sync)
    content_text=$(echo "$resp" | jq -r '.result.content[0].text // empty')
    task_id=$(echo "$content_text" | jq -r '.task_id // empty')

    if [ -n "$task_id" ]; then
        echo "   Background task: $task_id — polling task_status..."
        poll_id=10
        while true; do
            send "{\"jsonrpc\":\"2.0\",\"id\":${poll_id},\"method\":\"tools/call\",\"params\":{\"name\":\"task_status\",\"arguments\":{\"task_id\":\"${task_id}\"}}}"
            poll_resp=$(wait_response "$poll_id" 30)
            poll_text=$(echo "$poll_resp" | jq -r '.result.content[0].text // empty')
            status=$(echo "$poll_text" | jq -r '.status // empty')
            message=$(echo "$poll_text" | jq -r '.message // empty')
            elapsed_s=$(echo "$poll_text" | jq -r '.elapsed_secs // empty')
            echo "   [$elapsed_s s] status=$status message=$message"

            if [ "$status" = "completed" ]; then
                echo "   Task completed"
                # Legacy idat/.i64 opens usually return functions immediately.
                # IDA 9.4's native dscu path can complete the image load before
                # function analysis has produced entries, so accept a loaded
                # DSC image as the direct-path success signal.
                fc=$(echo "$poll_text" | jq -r '.result.function_count // empty')
                dsc_loaded=$(echo "$poll_text" | jq -r '.result.loaded_images[0].loaded // false')
                if { [ -z "$fc" ] || [ "$fc" = "0" ]; } && [ "$dsc_loaded" != "true" ]; then
                    echo "❌ Completed DSC task had neither function_count nor loaded DSC image"
                    cat "$log"
                    exit 1
                fi
                echo "   function_count=${fc:-0} loaded_image=$dsc_loaded"
                break
            elif [ "$status" = "failed" ]; then
                echo "❌ Task failed: $message"
                cat "$log"
                exit 1
            fi

            poll_id=$((poll_id + 1))
            sleep 5
        done
    else
        # Sync path — check for isError
        is_error=$(echo "$resp" | jq -r '.result.isError // false')
        if [ "$is_error" = "true" ]; then
            echo "❌ open_dsc returned error: $content_text"
            cat "$log"
            exit 1
        fi
        fc=$(echo "$content_text" | jq -r '.function_count // empty')
        echo "   Opened synchronously, function_count=$fc"
    fi

    # Phase 3: Snapshot function count and segments before adding dylib
    send '{"jsonrpc":"2.0","id":100,"method":"tools/call","params":{"name":"idb_meta","arguments":{}}}'
    meta_resp=$(wait_response 100 30)
    meta_error=$(echo "$meta_resp" | jq -r '.result.isError // false')
    if [ "$meta_error" = "true" ]; then
        echo "❌ idb_meta failed after open"
        echo "$meta_resp" | jq .
        cat "$log"
        exit 1
    fi
    meta_text=$(echo "$meta_resp" | jq -r '.result.content[0].text // empty')
    fc_before=$(echo "$meta_text" | jq -r '.function_count // 0')
    echo "   idb_meta OK — function_count=$fc_before"

    send '{"jsonrpc":"2.0","id":101,"method":"tools/call","params":{"name":"segments","arguments":{}}}'
    seg_resp=$(wait_response 101 30)
    seg_error=$(echo "$seg_resp" | jq -r '.result.isError // false')
    if [ "$seg_error" = "true" ]; then
        echo "❌ segments failed after open"
        echo "$seg_resp" | jq .
        cat "$log"
        exit 1
    fi
    seg_text=$(echo "$seg_resp" | jq -r '.result.content[0].text // empty')
    seg_before=$(echo "$seg_text" | jq -r 'if type == "array" then length else .segments | length end // 0')
    echo "   segments OK — count=$seg_before"

    # Phase 4: dsc_add_dylib — load an additional framework
    send '{"jsonrpc":"2.0","id":102,"method":"tools/call","params":{"name":"dsc_add_dylib","arguments":{"module":"/usr/lib/libSystem.B.dylib","timeout_secs":300}}}'
    add_resp=$(wait_response 102 300)
    add_error=$(echo "$add_resp" | jq -r '.result.isError // false')
    if [ "$add_error" = "true" ]; then
        echo "⚠️  dsc_add_dylib returned error (dscu plugin may not be available):"
        echo "$add_resp" | jq -r '.result.content[0].text // empty'
    else
        add_text=$(echo "$add_resp" | jq -r '.result.content[0].text // empty')
        add_ok=$(echo "$add_text" | jq -r '.success // false')
        if [ "$add_ok" = "true" ]; then
            echo "   dsc_add_dylib OK"
        else
            echo "⚠️  dsc_add_dylib did not report success: $add_text"
        fi
    fi

    # Phase 5: Verify DB state changed after add
    send '{"jsonrpc":"2.0","id":103,"method":"tools/call","params":{"name":"idb_meta","arguments":{}}}'
    meta2_resp=$(wait_response 103 30)
    meta2_text=$(echo "$meta2_resp" | jq -r '.result.content[0].text // empty')
    fc_after=$(echo "$meta2_text" | jq -r '.function_count // 0')
    echo "   After add: function_count=$fc_after (was $fc_before)"
    if [ "$fc_after" -gt "$fc_before" ]; then
        echo "   ✓ Function count increased by $((fc_after - fc_before))"
    else
        echo "⚠️  Function count did not increase (before=$fc_before, after=$fc_after)"
    fi

    send '{"jsonrpc":"2.0","id":104,"method":"tools/call","params":{"name":"segments","arguments":{}}}'
    seg2_resp=$(wait_response 104 30)
    seg2_text=$(echo "$seg2_resp" | jq -r '.result.content[0].text // empty')
    seg_after=$(echo "$seg2_text" | jq -r 'if type == "array" then length else .segments | length end // 0')
    echo "   After add: segments=$seg_after (was $seg_before)"
    if [ "$seg_after" -gt "$seg_before" ]; then
        echo "   ✓ Segment count increased by $((seg_after - seg_before))"
    else
        echo "⚠️  Segment count did not increase (before=$seg_before, after=$seg_after)"
    fi

    # Phase 6: analysis_status sanity check
    send '{"jsonrpc":"2.0","id":105,"method":"tools/call","params":{"name":"analysis_status","arguments":{}}}'
    as_resp=$(wait_response 105 30)
    as_error=$(echo "$as_resp" | jq -r '.result.isError // false')
    if [ "$as_error" = "true" ]; then
        echo "❌ analysis_status failed after add"
        exit 1
    fi
    echo "   analysis_status OK"

    # Phase 7: close
    send '{"jsonrpc":"2.0","id":200,"method":"tools/call","params":{"name":"close_idb","arguments":{}}}'
    wait_response 200 10 >/dev/null
    echo "   close_idb OK"

    echo "✅ DSC test passed"

# Clean test artifacts
clean:
    rm -f "{{ test_bin }}"
    rm -rf fixtures/mini.dSYM
    rm -f fixtures/*.i64 fixtures/*.idb
    rm -f fixtures/*.id0 fixtures/*.id1 fixtures/*.id2 fixtures/*.nam fixtures/*.til fixtures/*.imcp
